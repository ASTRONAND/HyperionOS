local args={...}
local kernel = args[1]

local data = kernel.fs.mkvirtfs("devfs0000", true, "devfs", false)

data["/"]["OSVERSION"]="Hyperion 1.0.0"
data["/"]["eeprom"]={
    __file=true,
    read=function()
        return kernel.computer:getEEPROM()
    end,
    write=function(text)
        if kernel.uid ~= 0 then error("Permission Denied") end
        kernel.computer:setEEPROM(text)
    end
}

