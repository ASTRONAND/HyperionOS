--:Minify:--
local kernel=...
for i,v in ipairs(string.split(kernel.fstab,"\n")) do
    if v:sub(1,1)=="U" then
        local id=""
        for i=3,#v do
            if v:sub(i,i)==";" then
                if i==3 then kernel.log("Invalid fstab line... Skipping.","WARN", 8) goto endline end
                id=v:sub(3,i-1)
            end
        end
        local path=v:sub(#id+4)
        if id~="$" then
            kernel.vfs.mount(path, id)
        end
        ::endline::
    end
end